# Set to "true" once you're ready to enforce login on /owner/* and
# /candidate/* routes (middleware.ts checks this). Left unset/false by
# default so you can preview the onboarding/browse pages without first
# building out the full auth flow.
AUTH_ENFORCEMENT_ENABLED=false

# Copy this file to .env.local and fill in real values.
# Get these from your Supabase project settings (Settings -> API).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. NEVER expose this to the client or commit it.
# Used only in src/lib/supabase/server.ts (createServiceClient) for
# trusted server operations like the payment webhook handler.
SUPABASE_SERVICE_ROLE_KEY=

# Dodo Payments (subscriptions + screening credit packs).
# TEMPORARY provider choice -- see src/lib/dodo/server.ts for why.
# Get your API key and webhook secret from the Dodo Payments dashboard.
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_ENVIRONMENT=test_mode
DODO_WEBHOOK_SECRET=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Create these as Products in your Dodo Payments dashboard (Standard/Pro
# as recurring subscription products, credit packs as one-time
# products), then paste their product IDs (prod_xxx) here.
DODO_PRODUCT_STANDARD=
DODO_PRODUCT_PRO=
DODO_PRODUCT_CREDITS_10=
DODO_PRODUCT_CREDITS_25=

# AI provider. Default is GitHub Models (free, Azure-hosted GPT) for
# early development -- see https://docs.github.com/en/github-models
# Get a free token from your GitHub account settings -> Developer settings
# -> Personal access tokens (needs `models: read` permission), or from
# the "Get API key" button on any model page at github.com/marketplace/models
AI_PROVIDER=github_models
GITHUB_MODELS_TOKEN=
GITHUB_MODELS_MODEL=openai/gpt-4o-mini

# Switch AI_PROVIDER to "anthropic" once you're ready to move off the free
# tier, and fill in the key below. No other code changes needed --
# see src/lib/ai/provider.ts, this is the only file that reads these.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Twilio (add in Phase 2 -- SMS screening invites and notification preferences)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
