# Copy this file to .env.local and fill in real values.
# Get these from your Supabase project settings (Settings -> API).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. NEVER expose this to the client or commit it.
# Used only in src/lib/supabase/server.ts (createServiceClient) for
# trusted server operations like the Stripe webhook handler.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (add once billing is wired up in Phase 1)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# AI provider. Default is GitHub Models (free, Azure-hosted GPT) for
# early development -- see https://docs.github.com/en/github-models
# Get a free token from your GitHub account settings -> Developer settings
# -> Personal access tokens (needs `models: read` permission), or from
# the "Get API key" button on any model page at github.com/marketplace/models
AI_PROVIDER=github_models
GITHUB_MODELS_TOKEN=
GITHUB_MODELS_MODEL=openai/gpt-4o-mini

# Switch AI_PROVIDER to "anthropic" once you're ready to move off the free
# tier, and fill in the key below. No other code changes needed --
# see src/lib/ai/provider.ts, this is the only file that reads these.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Twilio (add in Phase 2 -- SMS screening invites and notification preferences)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
