# Copy this file to .env.local and fill in real values.
# Get these from your Supabase project settings (Settings -> API).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. NEVER expose this to the client or commit it.
# Used only in src/lib/supabase/server.ts (createServiceClient) for
# trusted server operations like the Stripe webhook handler.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (add once billing is wired up in Phase 1)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# AI provider (add in Phase 2 -- AI search, outreach, advisor, screening)
ANTHROPIC_API_KEY=

# Twilio (add in Phase 2 -- SMS screening invites and notification preferences)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
